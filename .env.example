# Copy this file to `.env` in the project root and fill in real values.
# The loader (vid.builder.Env) reads this file at startup. Real process
# environment variables still take precedence when set.

# ------------------------------------------------------------------
# OpenAI — used by AIscraper (GPT-4o), VidBuilder (TTS) and Whisper
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here

# ------------------------------------------------------------------
# YouTube OAuth credentials — one client ID / secret / account email
# per channel so uploads can run concurrently without sharing quota.
# Create each client in the Google Cloud Console under
# "OAuth client ID" → "Desktop app".
# ------------------------------------------------------------------
CHANNEL_1_CLIENT_ID=
CHANNEL_1_CLIENT_SECRET=
CHANNEL_1_EMAIL=channel1@example.com

CHANNEL_2_CLIENT_ID=
CHANNEL_2_CLIENT_SECRET=
CHANNEL_2_EMAIL=channel2@example.com

CHANNEL_3_CLIENT_ID=
CHANNEL_3_CLIENT_SECRET=
CHANNEL_3_EMAIL=channel3@example.com

CHANNEL_4_CLIENT_ID=
CHANNEL_4_CLIENT_SECRET=
CHANNEL_4_EMAIL=channel4@example.com

CHANNEL_5_CLIENT_ID=
CHANNEL_5_CLIENT_SECRET=
CHANNEL_5_EMAIL=channel5@example.com
